(load "Test.carp")
(use Test)
(load "priority_queue.carp")
(use PriorityQueue)

(deftest priority-queue-test
  (let [pq (PriorityQueue.new)
        state (Test.State.init 0 0)
        
        ;; Test 1: Empty queue
        s1 (assert-true &state (PriorityQueue.empty? &pq) "Queue starts empty")
        s2 (assert-true &s1 (let [p (PriorityQueue.peek &pq)] (Maybe.nothing? &p)) "Peek on empty queue is Nothing")

        ;; Test 2: Push elements (Max-Heap)
        _ (do
            (PriorityQueue.push &pq 10 &IntRef.>)
            (PriorityQueue.push &pq 30 &IntRef.>)
            (PriorityQueue.push &pq 20 &IntRef.>))
        s3 (assert-equal &s2 3 (PriorityQueue.length &pq) "Length is 3 after 3 pushes")
        s4 (assert-equal &s3 &(Maybe.Just 30) &(PriorityQueue.peek &pq) "Peek returns 30 (max)")
        s5 (assert-true &s4 (PriorityQueue.valid? &pq &IntRef.>) "Heap is valid after pushes")

        ;; Test 3: from-array (Heapify)
        arr [10 50 20 40 30]
        pq2 (PriorityQueue.from-array arr &IntRef.>)
        s6 (assert-true &s5 (PriorityQueue.valid? &pq2 &IntRef.>) "Heapify produces valid heap")
        s7 (assert-equal &s6 &(Maybe.Just 50) &(PriorityQueue.pop &pq2 &IntRef.>) "from-array first pop 50")

        ;; Test 4: update-top!
        _2 (PriorityQueue.update-top! &pq &(fn [x] 5) &IntRef.>)
        s8 (assert-equal &s7 &(Maybe.Just 20) &(PriorityQueue.peek &pq) "update-top! 30->5 moves 20 to top")
        s9 (assert-true &s8 (PriorityQueue.valid? &pq &IntRef.>) "Heap is valid after update-top!")

        ;; Test 5: append!
        pq3 (PriorityQueue.new)
        _4 (PriorityQueue.push &pq3 100 &IntRef.>)
        _5 (PriorityQueue.append! &pq &pq3 &IntRef.>)
        s10 (assert-equal &s9 4 (PriorityQueue.length &pq) "Length is 4 after append!")
        s11 (assert-equal &s10 &(Maybe.Just 100) &(PriorityQueue.peek &pq) "append! worked, 100 is max")
        s12 (assert-true &s11 (PriorityQueue.valid? &pq &IntRef.>) "Heap is valid after append!")

        ;; Test 6: into-sorted-array
        sorted (PriorityQueue.into-sorted-array pq &IntRef.>)
        s13 (assert-equal &s12 4 (Array.length &sorted) "Sorted array length correct")
        s14 (assert-equal &s13 &[100 20 10 5] &sorted "into-sorted-array produced correct order")

        ;; Test 7: into-array
        pq4 (PriorityQueue.from-array [3 1 2] &IntRef.>)
        raw (PriorityQueue.into-array pq4)
        s15 (assert-equal &s14 3 (Array.length &raw) "into-array length correct")
        ]
    s15))
