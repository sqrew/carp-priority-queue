(load "Test.carp")
(use Test)
(load "priority_queue.carp")
(use PriorityQueue)
(use Random)

(deftest priority-queue-test
  (let [pq (PriorityQueue.new)
        state (Test.State.init 0 0)
        
        ;; Test 1: Empty queue
        s1 (assert-true &state (PriorityQueue.empty? &pq) "Queue starts empty")
        s2 (assert-true &s1 (let [p (PriorityQueue.peek &pq)] (Maybe.nothing? &p)) "Peek on empty queue is Nothing")

        ;; Test 2: Push elements (Max-Heap)
        _ (do
            (PriorityQueue.push! &pq 10 &IntRef.>)
            (PriorityQueue.push! &pq 30 &IntRef.>)
            (PriorityQueue.push! &pq 20 &IntRef.>))
        s3 (assert-equal &s2 3 (PriorityQueue.length &pq) "Length is 3 after 3 pushes")
        s4 (assert-equal &s3 &(Maybe.Just 30) &(PriorityQueue.peek &pq) "Peek returns 30 (max)")
        s5 (assert-true &s4 (PriorityQueue.valid? &pq &IntRef.>) "Heap is valid after pushes")

        ;; Test 3: pop!
        s6 (assert-equal &s5 &(Maybe.Just 30) &(PriorityQueue.pop! &pq &IntRef.>) "pop! returns 30")
        s7 (assert-equal &s6 2 (PriorityQueue.length &pq) "Length is 2 after pop!")

        ;; Test 4: Stress Test (Random)
        s8 (do
             (PriorityQueue.clear! &pq)
             (for [i 0 100] (PriorityQueue.push! &pq (Int.random-between 0 1000) &IntRef.>))
             (let [st (assert-equal &s7 100 (PriorityQueue.length &pq) "Stress test: 100 items pushed")
                   st2 (assert-true &st (PriorityQueue.valid? &pq &IntRef.>) "Stress test: heap property maintained")
                   last-val 1001
                   all-ordered true]
               (do
                 (for [i 0 100]
                   (let [v (Maybe.unsafe-from (PriorityQueue.pop! &pq &IntRef.>))]
                     (do
                       (if (> v last-val) (set! all-ordered false) ())
                       (set! last-val v))))
                 (assert-true &st2 all-ordered "Stress test: all elements popped in descending order"))))

        ;; Test 5: Search & Rescue (remove-at!, modify-at!)
        s11 (do
             (PriorityQueue.clear! &pq)
             (PriorityQueue.push! &pq 10 &IntRef.>)
             (PriorityQueue.push! &pq 20 &IntRef.>)
             (PriorityQueue.push! &pq 30 &IntRef.>)
             (let [idx (Maybe.unsafe-from (PriorityQueue.find-index &pq &(fn [x] (= @x 30))))
                   _ (PriorityQueue.remove-at! &pq idx &IntRef.>)
                   st (assert-equal &s8 2 (PriorityQueue.length &pq) "Length correct after remove-at!")
                   st2 (assert-true &st (PriorityQueue.valid? &pq &IntRef.>) "Heap valid after remove-at!")
                   st3 (assert-equal &st2 &(Maybe.Just 20) &(PriorityQueue.peek &pq) "Peek correct after remove-at!")]
               (do
                 (ignore (PriorityQueue.modify-at! &pq 0 &(fn [x] 100) &IntRef.>))
                 (let [st4 (assert-equal &st3 &(Maybe.Just 100) &(PriorityQueue.peek &pq) "modify-at! updated top")]
                   (assert-true &st4 (PriorityQueue.valid? &pq &IntRef.>) "Heap valid after modify-at!")))))

        ;; Test 6: retain!
        s15 (do
             (PriorityQueue.push! &pq 5 &IntRef.>)
             (PriorityQueue.push! &pq 200 &IntRef.>)
             (PriorityQueue.retain! &pq &(fn [x] (> @x 50)) &IntRef.>)
             (let [st (assert-equal &s11 2 (PriorityQueue.length &pq) "retain! kept 2 elements")]
               (assert-true &st (PriorityQueue.valid? &pq &IntRef.>) "Heap valid after retain!")))

        ;; Test 7: Duplicates & Degenerate
        s17 (do
             (PriorityQueue.clear! &pq)
             (PriorityQueue.push! &pq 5 &IntRef.>)
             (PriorityQueue.push! &pq 5 &IntRef.>)
             (let [st (assert-equal &s15 2 (PriorityQueue.length &pq) "Duplicates pushed correctly")
                   st2 (assert-true &st (PriorityQueue.valid? &pq &IntRef.>) "Heap valid with duplicates")]
               (do
                 (ignore (PriorityQueue.pop! &pq &IntRef.>))
                 (let [st3 (assert-equal &st2 1 (PriorityQueue.length &pq) "Popped duplicate correctly")
                       _ (PriorityQueue.remove-at! &pq 0 &IntRef.>)
                       st4 (assert-true &st3 (PriorityQueue.empty? &pq) "Remove-at! on size 1 works")]
                   (do
                     (ignore (PriorityQueue.rebuild! &pq &IntRef.>))
                     (assert-true &st4 (PriorityQueue.empty? &pq) "Rebuild on empty heap works"))))))
        ]
    s17))
