(load "Test.carp")
(use Test)
(load "priority_queue.carp")
(use PriorityQueue)

(deftest priority-queue-test
  (let [pq (PriorityQueue.new)
        state (Test.State.init 0 0)
        
        ;; Test 1: Empty queue
        s1 (assert-true &state (PriorityQueue.empty? &pq) "Queue starts empty")
        s2 (assert-true &s1 (let [p (PriorityQueue.peek &pq)] (Maybe.nothing? &p)) "Peek on empty queue is Nothing")

        ;; Test 2: Push elements (Max-Heap)
        _ (do
            (PriorityQueue.push &pq 10 &IntRef.>)
            (PriorityQueue.push &pq 30 &IntRef.>)
            (PriorityQueue.push &pq 20 &IntRef.>))
        s3 (assert-equal &s2 3 (PriorityQueue.length &pq) "Length is 3 after 3 pushes")
        s4 (assert-equal &s3 &(Maybe.Just 30) &(PriorityQueue.peek &pq) "Peek returns 30 (max)")

        ;; Test 3: Pop elements
        s5 (assert-equal &s4 &(Maybe.Just 30) &(PriorityQueue.pop &pq &IntRef.>) "First pop is 30")
        s6 (assert-equal &s5 &(Maybe.Just 20) &(PriorityQueue.pop &pq &IntRef.>) "Second pop is 20")
        s7 (assert-equal &s6 &(Maybe.Just 10) &(PriorityQueue.pop &pq &IntRef.>) "Third pop is 10")
        s8 (assert-true &s7 (PriorityQueue.empty? &pq) "Queue is empty after popping all elements")

        ;; Test 4: Min-Heap behavior
        _2 (do
             (PriorityQueue.push &pq 50 &IntRef.<)
             (PriorityQueue.push &pq 10 &IntRef.<)
             (PriorityQueue.push &pq 100 &IntRef.<))
        s9 (assert-equal &s8 &(Maybe.Just 10) &(PriorityQueue.pop &pq &IntRef.<) "Min-heap pop is 10")
        s10 (assert-equal &s9 &(Maybe.Just 50) &(PriorityQueue.pop &pq &IntRef.<) "Min-heap pop is 50")
        s11 (assert-equal &s10 &(Maybe.Just 100) &(PriorityQueue.pop &pq &IntRef.<) "Min-heap pop is 100")
        ]
    s11))
